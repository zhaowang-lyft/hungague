{
  "manifest_version": 3,
  "name": "Hunger Gauge",
  "version": "1.0.1",
  "description": "Rate and review dishes from your HungerHub orders",
  "permissions": ["storage"],
  "host_permissions": [
    "*://uncatering.hungerhub.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://uncatering.hungerhub.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hungerhub-ratings@local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
